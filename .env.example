# Discord Bot Token
DISCORD_TOKEN=your_token_here

# Lavalink Node 1
LAVALINK_HOST_1=lavalink-server-1.com
LAVALINK_PORT_1=2333
LAVALINK_PASSWORD_1=youshallnotpass

# Lavalink Node 2 (optional)
LAVALINK_HOST_2=lavalink-server-2.com
LAVALINK_PORT_2=2334
LAVALINK_PASSWORD_2=youshallnotpass

# Lavalink Node 3 (optional)
LAVALINK_HOST_3=lavalink-server-3.com
LAVALINK_PORT_3=2335
LAVALINK_PASSWORD_3=youshallnotpass

# Spotify Credentials
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Bot Settings
PREFIX=/

# Web Server
WEB_PORT=5000
WEB_HOST=0.0.0.0

# Retry Settings
MAX_RETRY=5
RETRY_DELAY=5
